<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="match_parent">

        <TextView android:id="@+id/scoreA" android:text="0" android:textSize="54sp" android:gravity="center" android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button android:id="@+id/btnA" android:text="PONTO" android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="match_parent">

        <TextView android:id="@+id/scoreB" android:text="0" android:textSize="54sp" android:gravity="center" android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button android:id="@+id/btnB" android:text="PONTO" android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>